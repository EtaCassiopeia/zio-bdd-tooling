<idea-plugin>
    <id>zio.bdd</id>
    <name>zio-bdd</name>
    <vendor>zio-bdd</vendor>

    <description><![CDATA[
        IDE support for the zio-bdd Scala 3 / ZIO 2 BDD test framework.<br/>
        Owns <code>.feature</code> files — does not require the Gherkin plugin.<br/>
        <ul>
            <li>Syntax highlighting for <code>.feature</code> files (keywords, tags, <code>@flags</code>, doc strings, tables)</li>
            <li>Customisable colour scheme — Settings → Editor → Color Scheme → zio-bdd Gherkin</li>
            <li>Go-to-definition: Cmd+Click a step → jump to its Scala source</li>
            <li>Diagnostics: missing step definitions highlighted with closest-match hints</li>
            <li>Autocomplete: step suggestions in <code>.feature</code> files</li>
            <li>Hover: parameter types and extractor names for matched steps</li>
            <li>Run configurations: right-click a Scenario or click the gutter ▶ icon to run it</li>
        </ul>
        Self-contained — no external plugins or compile step required.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── File type & language ───────────────────────────────────────── -->
        <fileType name="Gherkin Feature"
                  implementationClass="zio.bdd.intellij.lang.ZioBddFileType"
                  fieldName="INSTANCE"
                  language="ZioBddGherkin"
                  extensions="feature"/>

        <!-- ── Syntax highlighting ────────────────────────────────────────── -->
        <lang.syntaxHighlighterFactory
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="zio.bdd.intellij.lang.ZioBddColorSettingsPage"/>

        <!-- ── Native PSI parser ──────────────────────────────────────────── -->
        <lang.parserDefinition
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddParserDefinition"/>

        <!-- ── Sub-line syntax highlighting (keyword vs title vs step text) ── -->
        <annotator
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddSyntaxAnnotator"/>

        <!-- ── Step validation ────────────────────────────────────────────── -->
        <annotator
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddAnnotator"/>

        <!-- ── Go-to-definition ───────────────────────────────────────────── -->
        <gotoDeclarationHandler
                implementation="zio.bdd.intellij.lang.ZioBddGotoStepHandler"/>

        <!-- ── Code completion ────────────────────────────────────────────── -->
        <completion.contributor
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddCompletionContributor"
                order="first"/>

        <!-- ── Run gutter icons (feature files) ─────────────────────────── -->
        <codeInsight.lineMarkerProvider
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddLineMarkerProvider"/>

        <!-- ── Find-usages gutter on Scala step definitions ─────────────── -->
        <codeInsight.lineMarkerProvider
                language="Scala"
                implementationClass="zio.bdd.intellij.lang.ZioBddStepDefLineMarkerProvider"/>

        <!-- ── Run configurations ─────────────────────────────────────────── -->
        <configurationType
                implementation="zio.bdd.intellij.execution.ZioBddRunConfigurationType"/>

        <runConfigurationProducer
                implementation="zio.bdd.intellij.execution.ZioBddRunConfigurationProducer"/>

        <!-- ── Per-project step-definition cache ─────────────────────────── -->
        <projectService
                serviceImplementation="zio.bdd.intellij.lang.ZioBddStepCache"/>

        <!-- ── Invalidate step cache when .scala files change ────────────── -->
        <projectActivity
                implementation="zio.bdd.intellij.lang.ZioBddFileChangeListener"/>

        <!-- ── Hover docs for matched steps ─────────────────────────────── -->
        <lang.documentationProvider
                language="ZioBddGherkin"
                implementationClass="zio.bdd.intellij.lang.ZioBddDocumentationProvider"/>

        <!-- ── Scenario Explorer tool window ─────────────────────────────── -->
        <toolWindow id="Scenario Explorer"
                    anchor="left"
                    factoryClass="zio.bdd.intellij.toolwindow.ZioBddScenarioExplorerFactory"
                    icon="/icons/feature.svg"/>

    </extensions>

    <actions>
        <action id="zio.bdd.FindStepUsages"
                class="zio.bdd.intellij.lang.ZioBddFindStepUsagesAction"
                text="Find Step Usages"
                description="Find all feature file steps that share this step definition">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="GotoDeclaration"/>
        </action>
    </actions>


</idea-plugin>
