{
  "name": "zio-bdd",
  "displayName": "zio-bdd",
  "description": "IDE support for zio-bdd Scala BDD test framework — syntax highlighting, go-to-definition, diagnostics, completion, and run configurations for .feature files.",
  "version": "0.1.0",
  "publisher": "zio-bdd",
  "repository": {
    "type": "git",
    "url": "https://github.com/EtaCassiopeia/zio-bdd-tooling"
  },
  "license": "Apache-2.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Testing", "Programming Languages"],
  "keywords": ["scala", "zio", "bdd", "gherkin", "feature", "test"],
  "galleryBanner": { "color": "#0f1923", "theme": "dark" },
  "qna": "https://github.com/EtaCassiopeia/zio-bdd-tooling/discussions",
  "activationEvents": [
    "workspaceContains:**/*.feature",
    "onLanguage:gherkin",
    "onView:zioBdd.scenarioExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zio-bdd",
          "title": "zio-bdd",
          "icon": "images/bdd-icon.svg"
        }
      ]
    },
    "views": {
      "zio-bdd": [
        {
          "type": "webview",
          "id": "zioBdd.scenarioExplorer",
          "name": "Scenario Explorer"
        }
      ]
    },
    "languages": [
      {
        "id": "gherkin",
        "aliases": ["Gherkin", "Feature"],
        "extensions": [".feature"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "text.gherkin.ziobdd",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "zio-bdd.runCommand",
        "title": "zio-bdd: Run sbt Command"
      },
      {
        "command": "zio-bdd.restartServer",
        "title": "zio-bdd: Restart Language Server"
      },
      {
        "command": "zio-bdd.showOutput",
        "title": "zio-bdd: Show Output Channel"
      },
      {
        "command": "zio-bdd.refreshSidebar",
        "title": "zio-bdd: Refresh Scenario Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "zio-bdd.findStepUsages",
        "title": "zio-bdd: Find Step Usages"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "zio-bdd.refreshSidebar",
          "when": "view == zioBdd.scenarioExplorer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "zio-bdd",
      "properties": {
        "zio-bdd.lspBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the zio-bdd-lsp binary. Leave empty to use the bundled binary."
        },
        "zio-bdd.sbtCommand": {
          "type": "string",
          "default": "sbt",
          "description": "sbt command to use for running tests (e.g. './sbtx' or 'sbt -J-Xmx4g')."
        },
        "zio-bdd.logLevel": {
          "type": "string",
          "enum": ["off", "error", "warn", "info", "debug"],
          "default": "info",
          "description": "LSP server log verbosity."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile": "npm run typecheck && npm run bundle",
    "watch": "npm run bundle -- --watch",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.26.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
