{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gherkin (zio-bdd)",
  "scopeName": "text.gherkin.ziobdd",
  "fileTypes": ["feature"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#tag" },
    { "include": "#feature-keyword" },
    { "include": "#rule-keyword" },
    { "include": "#scenario-keyword" },
    { "include": "#background-keyword" },
    { "include": "#examples-keyword" },
    { "include": "#step" },
    { "include": "#table" },
    { "include": "#docstring-triple-quote" },
    { "include": "#docstring-backtick" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.gherkin",
      "match": "^\\s*#.*$"
    },
    "tag": {
      "patterns": [
        {
          "comment": "@flags(k=v) — highlight key=value pairs distinctly",
          "match": "(@flags)\\(([^)]+)\\)",
          "captures": {
            "1": { "name": "entity.name.tag.flags.gherkin" },
            "2": { "name": "constant.other.flags.gherkin" }
          }
        },
        {
          "name": "entity.name.tag.gherkin",
          "match": "@[\\w\\-\\.]+"
        }
      ]
    },
    "feature-keyword": {
      "name": "keyword.control.feature.gherkin",
      "match": "^\\s*(Feature:|Ability:|Business Need:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.feature.gherkin" },
        "2": { "name": "entity.name.section.gherkin" }
      }
    },
    "rule-keyword": {
      "match": "^\\s*(Rule:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.rule.gherkin" },
        "2": { "name": "entity.name.section.gherkin" }
      }
    },
    "scenario-keyword": {
      "match": "^\\s*(Scenario Outline:|Scenario Template:|Scenario:|Example:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.scenario.gherkin" },
        "2": { "name": "entity.name.function.scenario.gherkin" }
      }
    },
    "background-keyword": {
      "match": "^\\s*(Background:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.background.gherkin" },
        "2": { "name": "entity.name.section.gherkin" }
      }
    },
    "examples-keyword": {
      "match": "^\\s*(Examples:|Scenarios:)\\s*(.*)$",
      "captures": {
        "1": { "name": "keyword.control.examples.gherkin" },
        "2": { "name": "entity.name.section.gherkin" }
      }
    },
    "step": {
      "match": "^\\s*(Given|When|Then|And|But|\\*)\\s+(.*)$",
      "captures": {
        "1": { "name": "keyword.other.step.gherkin" },
        "2": {
          "patterns": [
            { "include": "#placeholder" }
          ]
        }
      }
    },
    "placeholder": {
      "name": "variable.other.placeholder.gherkin",
      "match": "<[^>]+>"
    },
    "table": {
      "name": "meta.table.gherkin",
      "match": "^\\s*(\\|)([^|]*)(\\|)+$",
      "captures": {
        "1": { "name": "punctuation.separator.table.gherkin" },
        "2": { "name": "string.unquoted.table-cell.gherkin" }
      }
    },
    "docstring-triple-quote": {
      "name": "string.quoted.triple.gherkin",
      "begin": "^\\s*\"\"\"",
      "end": "^\\s*\"\"\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.gherkin" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.gherkin" }
      }
    },
    "docstring-backtick": {
      "name": "string.quoted.backtick.gherkin",
      "begin": "^\\s*```",
      "end": "^\\s*```",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.gherkin" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.gherkin" }
      }
    }
  }
}
